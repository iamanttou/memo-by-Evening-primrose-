<body>

<header>
📝 Pastel Memo
</header>

<div class="container">

<div class="card">

<textarea id="memo" placeholder="メモを書く..."></textarea>

<div class="buttons">
<button class="save" onclick="saveMemo()">保存</button>
<button class="clear" onclick="clearMemo()">削除</button>

<label class="upload">
画像を追加
<input type="file" id="imageInput" accept="image/*">
</label>
</div>

<div id="images"></div>

</div>

</div>

<script>
const memo=document.getElementById("memo");
const images=document.getElementById("images");

memo.value=localStorage.getItem("memo")||"";

const savedImages=JSON.parse(localStorage.getItem("images")||"[]");

savedImages.forEach(addImage);

function saveMemo(){
    localStorage.setItem("memo",memo.value);
    alert("保存しました");
}

function clearMemo(){
    if(confirm("削除しますか？")){
        memo.value="";
        images.innerHTML="";
        localStorage.removeItem("memo");
        localStorage.removeItem("images");
    }
}

document.getElementById("imageInput").addEventListener("change",e=>{
    const file=e.target.files[0];
    if(!file)return;

    const reader=new FileReader();

    reader.onload=function(ev){
        const data=ev.target.result;

        addImage(data);

        const list=JSON.parse(localStorage.getItem("images")||"[]");
        list.push(data);
        localStorage.setItem("images",JSON.stringify(list));
    }

    reader.readAsDataURL(file);
});

function addImage(src){
    const img=document.createElement("img");
    img.src=src;
    images.appendChild(img);
}
</script>

